{
  "dns": {
    "servers": [
      {
        "tag": "google",
        "type": "tls",
        "server": "dns.google",
        "domain_resolver": "?"
      },
      {
        "tag": "?",
        "type": "tls",
        "server": "?"
      },
      {
        "tag": "block",
        "type": "tls",
        "server": "?"
      }
    ],
    "rules": [
      {
        "rule_set": [
          "gfw"
        ],
        "server": "google"
      },
      {
        "rule_set": "ads",
        "server": "block"
      }
    ],
    "final": "?",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "address": [
        "172.20.0.1/30"
      ],
      "auto_route": true,
      "sniff": true
    }
  ],
  "outbounds": [
    {
      "tag": "site?",
      "type": "hysteria2",
      "server": "?",
      "server_port": 1234,
      "password": "?",
      "tls": {
        "enabled": true
      }
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "block",
      "type": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "rule_set": [
          "gfw"
        ],
        "outbound": "site?"
      },
      {
        "rule_set": [
          "ads"
        ],
        "outbound": "block"
      },
      {
        "rule_set": [
          "cn"
        ],
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "gfw",
        "type": "remote",
        "format": "binary",
        "url": "?",
        "download_detour": "site?"
      },
      {
        "tag": "ads",
        "type": "remote",
        "format": "binary",
        "url": "?",
        "download_detour": "site?"
      },
      {
        "tag": "?",
        "type": "local",
        "format": "source",
        "path": "?"
      }
    ]
  },
  "endpoints": [],
  "experimental": {},
  "log": {}
}
